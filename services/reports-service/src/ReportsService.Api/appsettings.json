{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReportsService": {
    "Security": {
      "IssuerUri": "http://localhost:18081/issuer",
      "JwkSetUri": "http://localhost:18081/.well-known/jwks.json",
      "Audience": "reports-service",
      "RolesClaim": "ROLES",
      "JwksCacheTtl": "00:05:00"
    },
    "Authz": {
      "RoleAccessKeyPrefix": "role_access:",
      "LocalCacheTtl": "00:00:05"
    },
    "RedisUrl": "redis://localhost:6379"
  }
}
